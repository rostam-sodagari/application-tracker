# Copy this file to .env and fill in real values. Never commit .env.

# --- backend mode ---------------------------------------------------------------
# "local" (default) needs no external account: data lives in a SQLite file and CV files on local
# disk, both under backend/data. "appwrite" uses an Appwrite Cloud project for both login and data.
BACKEND_MODE=local

# --- local mode ------------------------------------------------------------------
# Signs local-mode session tokens and email verification links. Required before using local mode
# for anything but a quick try; without it, restarting the process invalidates every session.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
LOCAL_SESSION_SECRET=

# The origin the frontend is served from. Used to build the link inside verification emails.
APP_BASE_URL=http://localhost:8000

# Outgoing mail for local-mode account verification, entirely optional. Leave SMTP_HOST unset to
# skip verification altogether: newly registered accounts are marked verified immediately, since a
# server with no mail provider configured has no way to ever deliver a verification link.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=

# --- appwrite mode -----------------------------------------------------------------
# From your Appwrite Cloud project's Settings -> General. Neither is secret.
APPWRITE_ENDPOINT=https://<REGION>.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=

# Used only for login verification (app/auth_providers/appwrite_auth.py) — accounts are created
# through open self-registration directly against Appwrite's own account service; this app never
# handles a password directly in this mode. Appwrite's own built-in email verification handles
# confirming an address, configured in the Appwrite console under Auth -> Settings, and a custom
# SMTP provider under Messaging if you do not want to rely on Appwrite Cloud's own default sender.
# (No extra config needed here beyond the endpoint/project ID above.)

# Used for all application data (app/stores/appwrite_store.py: TablesDB + Storage) — applications,
# CV files, and per-user settings. This IS a secret, unlike the two values above. Create it in the
# Appwrite console under Overview -> Integrations -> API Keys, with Databases + Storage read/write
# scope. Run scripts/init_appwrite_schema.py once after setting this to create the tables/bucket.
APPWRITE_API_KEY=
