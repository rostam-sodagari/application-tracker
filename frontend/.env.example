# Copy to .env.local (Vite auto-loads it, gitignored). Both values are public/non-secret — they
# end up in the built JS bundle. Used only for login (Appwrite Account service); all actual data
# still goes through the FastAPI backend, not Appwrite.
VITE_APPWRITE_ENDPOINT=https://<REGION>.cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=<PROJECT_ID>
